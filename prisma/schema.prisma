generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum SplitType {
  EQUAL
  PERCENTAGE
  FIXED
}

model User {
  id         String   @id @default(uuid()) @db.Uuid
  email      String   @unique
  name       String
  created_at DateTime @default(now())

  created_groups      Group[]        @relation("GroupCreator")
  group_members       GroupMember[]
  expenses_paid       Expense[]      @relation("ExpensePayer")
  expense_splits      ExpenseSplit[]
  settlements_from    Settlement[]   @relation("SettlementFrom")
  settlements_to      Settlement[]   @relation("SettlementTo")
  settlements_created Settlement[]   @relation("SettlementCreator")

  @@map("users")
}

model Group {
  id            String   @id @default(uuid()) @db.Uuid
  name          String
  invite_code   String   @unique
  created_by    String   @db.Uuid
  created_at    DateTime @default(now())
  base_currency String   @default("INR")

  creator     User          @relation("GroupCreator", fields: [created_by], references: [id])
  members     GroupMember[]
  expenses    Expense[]
  settlements Settlement[]

  @@index([created_by])
  @@map("groups")
}

model GroupMember {
  id        String   @id @default(uuid()) @db.Uuid
  group_id  String   @db.Uuid
  user_id   String   @db.Uuid
  joined_at DateTime @default(now())

  group Group @relation(fields: [group_id], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([group_id, user_id])
  @@index([group_id])
  @@index([user_id])
  @@map("group_members")
}

model Expense {
  id           String    @id @default(uuid()) @db.Uuid
  group_id     String    @db.Uuid
  paid_by      String    @db.Uuid
  title        String
  total_amount Decimal   @db.Decimal(12, 2)
  split_type   SplitType
  created_at   DateTime  @default(now())

  // Recurring expense fields
  is_recurring         Boolean   @default(false)
  recurrence_rule      String?
  recurrence_day       Int?
  next_due_date        DateTime?
  parent_expense_id    String?   @db.Uuid
  recurrence_anchor_id String?   @db.Uuid

  // Receipt attachment
  receipt_url      String?
  receipt_filename String?

  // Multi-currency
  currency            String  @default("INR")
  fx_rate_at_creation Decimal @default(1) @db.Decimal(18, 8)

  group  Group          @relation(fields: [group_id], references: [id], onDelete: Cascade)
  payer  User           @relation("ExpensePayer", fields: [paid_by], references: [id])
  splits ExpenseSplit[]

  @@index([group_id])
  @@index([paid_by])
  @@index([next_due_date])
  @@map("expenses")
}

model RecurringLog {
  id           String   @id @default(uuid()) @db.Uuid
  expense_id   String   @db.Uuid
  anchor_id    String   @db.Uuid
  generated_at DateTime @default(now())
  due_date     DateTime
  status       String

  @@index([anchor_id])
  @@map("recurring_logs")
}

model ExpenseSplit {
  id         String   @id @default(uuid()) @db.Uuid
  expense_id String   @db.Uuid
  user_id    String   @db.Uuid
  amount     Decimal  @db.Decimal(12, 2)
  percentage Decimal? @db.Decimal(5, 2)

  expense Expense @relation(fields: [expense_id], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([expense_id, user_id])
  @@index([expense_id])
  @@index([user_id])
  @@map("expense_splits")
}

model Settlement {
  id         String   @id @default(uuid()) @db.Uuid
  group_id   String   @db.Uuid
  from_user  String   @db.Uuid
  to_user    String   @db.Uuid
  amount     Decimal  @db.Decimal(12, 2)
  settled_at DateTime @default(now())
  created_by String   @db.Uuid

  group   Group @relation(fields: [group_id], references: [id], onDelete: Cascade)
  from    User  @relation("SettlementFrom", fields: [from_user], references: [id])
  to      User  @relation("SettlementTo", fields: [to_user], references: [id])
  creator User  @relation("SettlementCreator", fields: [created_by], references: [id])

  @@index([group_id])
  @@index([from_user])
  @@index([to_user])
  @@map("settlements")
}
